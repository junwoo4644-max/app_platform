# 서버 1 (portal + leaf_area) 배포용 환경 변수. 복사해서 .env로 저장 후 값을 채우세요.
# cp .env.example .env

# 도메인이 생기기 전까지는 서버의 공인 IP를 그대로 사용하세요, 예: http://161.33.13.xxx
NEXTAUTH_URL=http://localhost

# openssl rand -base64 32
NEXTAUTH_SECRET=랜덤_문자열로_교체

# 최초 기동 시 이 이메일/비밀번호로 포털 관리자 계정이 자동 생성됩니다.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=바꿔주세요
